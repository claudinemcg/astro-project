---
import Button from "../components/Button.astro";
import Heading from "../components/Heading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const headings = [
    { tag: "h1", size: "h2", text: "Heading 1" },
    { tag: "h2", size: "h3", text: "Heading 2" },
    { tag: "h3", size: "h4", text: "Heading 3" },
];
---

<BaseLayout>
    <h1>Heading Lesson</h1>

    <Button color={"white"} id={"my-id"}>Click me</Button>

    <Heading tag={"h2"}>This is a H2</Heading>
    <Heading tag={"h3"}>This is a H3</Heading>
    <Heading tag={"h4"}>This is a H4</Heading>
    <Heading tag={"h5"}>This is a H5</Heading>

    <Heading tag="h1" size="h6">This is my heading using sizes</Heading>

    <!-- Using const headings -->
    {
        headings.map((heading) => (
            <Heading tag={heading.tag} size={heading.size}>
                {heading.text}
            </Heading>
        ))
    }
    <!-- why use headings.map((heading) => ( ...
    instead of   headings.map((heading) => { ...
    it's a shorter syntax, and avoids the need for a return statement since the expression is implicitly returned. You would need a return statement if you weren't returning a value from the function.
    e.g.{headings.map((heading) => {
        const uppercaseText = heading.text.toUpperCase();
        return (
            <Heading tag={heading.tag} size={heading.size}>{uppercaseText}</Heading>
        );
    }); }
    -->

    -->
</BaseLayout>

<style>
    @import "https://unpkg.com/open-props";
    @import "https://unpkg.com/open-props/normalize.min.css";
    body {
        display: grid;
        place-content: center;
        gap: 1.5rem;
        padding: 1.5rem;
    }
</style>
