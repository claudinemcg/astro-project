---
const sizes: Record<string, string> = {
    h1: "h1",
    h2: "h2",
    h3: "h3",
    h4: "h4",
    h5: "h5",
    h6: "h6",
};

const { tag, size = "h2", ...rest } = Astro.props;
const CustomTag = tag;
---

<CustomTag class:list={["default", sizes[size]]} {...rest}>
    <slot />
</CustomTag>

<style>
    .h1 {
        font-size: 2.25rem;
        font-weight: 700;
    }
    .h2 {
        font-size: 1.875rem;
        font-weight: 700;
    }
    .h3 {
        font-size: 1.5rem;
        font-weight: 600;
    }
    .h4 {
        font-size: 1.25rem;
        font-weight: 600;
    }
    .h5 {
        font-size: 1.125rem;
        font-weight: 600;
    }
    .h6 {
        font-size: 1rem;
        font-weight: 600;
    }
</style>
