---
const {
    isBordered,
    classList = ["blue red"],
    background = "blue",
    color = "white",
    ...rest
} = Astro.props;
// background = "blue"- blue is default and anything passed in will override it
---

<!-- <button class:list={["btn", ["blue", "red"], { bordered: true }]}> -->
<button class:list={["btn", classList, { bordered: isBordered }]} {...rest}>
    <slot />
</button>

<style define:vars={{ background, color }}>
    .btn {
        background-color: var(--background);
        color: var(--color);
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 0.5rem;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
    }

    .btn:hover {
        opacity: 0.8;
    }
</style>
