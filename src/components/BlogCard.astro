---
/* const {
    label,
    labelColor,
    heading,
    description,
    author,
    date,
    thumbnail,
    author_image,
    } = Astro.props; */

const { blogpost } = Astro.props;
// blogposts.json now holds the array of posts so this destructures each one
// blogpost.label, blogpost.labelColor, blogpost.heading, blogpost.description, blogpost.author, blogpost.date, blogpost.thumbnail, blogpost.author_image

const bgColor = blogpost.labelColor ?? "bg-gray-600";

function formatDate(dateStr: string) {
    const now = new Date();
    const d = new Date(dateStr);

    const nowMidnight = new Date(
        now.getFullYear(),
        now.getMonth(),
        now.getDate(),
    );
    const dMidnight = new Date(
        d.getUTCFullYear(),
        d.getUTCMonth(),
        d.getUTCDate(),
    );
    const diffDays = Math.round(
        (nowMidnight.getTime() - dMidnight.getTime()) / 86400000,
    );

    if (diffDays === 0) {
        const diffHours = Math.floor((now.getTime() - d.getTime()) / 3600000);
        return diffHours < 1 ? "Just now" : `${diffHours}h ago`;
    }
    if (diffDays === 1) return "Yesterday";

    return d.toLocaleDateString("en-GB", {
        day: "numeric",
        month: "short",
        year: "numeric",
        timeZone: "UTC",
    });
}

const formattedDate = formatDate(blogpost.date);
---

<div class="blog_card">
    <div class="blog_image-wrapper">
        <img class="blog_image" src={blogpost.thumbnail} />
    </div>
    <div class="blog_content">
        <div class="blog_content-top">
            <div class="inline-flex">
                <div
                    class={`${blogpost.bgColor} text-white font-semibold px-4 py-1 rounded-full text-sm`}
                >
                    {blogpost.label}
                </div>
            </div>
            <h2 class="blog_heading text-lg md:text-xl font-semibold">
                {blogpost.heading}
            </h2>
            <p class="blog_description">{blogpost.description}</p>
        </div>

        <div class="blog_content-bottom">
            <div class="author_image-wrapper">
                <img
                    class="author_image w-16 h-16 rounded-full object-cover"
                    src={blogpost.author_image}
                />
            </div>
            <div class="author_content">
                <h3 class="author_name">{blogpost.author}</h3>
                <span class="blog_date">{formattedDate}</span>
            </div>
        </div>
    </div>
</div>

<style>
    .blog_card {
        display: flex;
        flex-direction: column;

        border-radius: 1rem;
        background-color: white;
        overflow: hidden;
    }

    .blog_image-wrapper {
        position: relative;
        overflow: hidden;
        height: 12rem;
    }

    .blog_image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .blog_content {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex: 1;
    }

    .blog_content-top {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .blog_content-bottom {
        display: flex;
        flex-direction: row;
        gap: 1rem;
        margin-top: auto;
        align-items: center;
        padding-top: 2rem;
    }

    .author_image-wrapper {
        flex-shrink: 0;
    }

    .author_content {
        display: flex;
        flex-direction: column;
    }

    .author_name {
        font-size: 1rem;
        font-weight: bold;
    }

    .blog_date {
        font-size: 1rem;
        color: var(--color);
    }

    .blog_description {
        font-size: 1rem;
        line-height: 1.5;
    }
</style>
